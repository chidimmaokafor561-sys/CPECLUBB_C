#include <stdio.h>
#include <string.h>

#define MAX 100

// Struct definition
struct Contact {
    char name[50];
    char phone[20];
};

// Function to add contact using pointer
void addContact(struct Contact *c) {
    printf("\nEnter name: ");
    scanf(" %[^\n]", c->name);

    printf("Enter phone number: ");
    scanf(" %[^\n]", c->phone);
}

// Function to display contacts using pointer
void displayContacts(struct Contact *c, int count) {
    printf("\n--- Phone Book ---\n");

    for (int i = 0; i < count; i++) {
        printf("\nContact %d\n", i + 1);
        printf("Name: %s\n", (c + i)->name);
        printf("Phone: %s\n", (c + i)->phone);
    }
}

int main() {
    struct Contact phoneBook[MAX];
    int choice, count = 0;

    while (1) {
        printf("\n\nPHONE BOOK MENU");
        printf("\n1. Add Contact");
        printf("\n2. Display Contacts");
        printf("\n3. Exit");
        printf("\nEnter choice: ");
        scanf("%d", &choice);

        if (choice == 1) {
            if (count < MAX) {
                addContact(&phoneBook[count]);
                count++;
            } else {
                printf("Phone book full!\n");
            }
        }
        else if (choice == 2) {
            if (count == 0) {
                printf("No contacts yet!\n");
            } else {
                displayContacts(phoneBook, count);
            }
        }
        else if (choice == 3) {
            printf("Exiting...\n");
            break;
        }
        else {
            printf("Invalid choice!\n");
        }
    }

    return 0;
}
